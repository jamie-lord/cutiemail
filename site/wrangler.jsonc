{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cutiemail-site",
  "compatibility_date": "2025-06-01",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "cuti.email", "custom_domain": true }
  ]
}
